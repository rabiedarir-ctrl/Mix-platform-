import * as THREE from "three";

// إنشاء Audio Listener وربطه بالكاميرا
const listener = new THREE.AudioListener();
camera.add(listener);

// إنشاء مصدر صوتي
const dreamSound = new THREE.Audio(listener);

// تحميل الملف
const audioLoader = new THREE.AudioLoader();
audioLoader.load('/assets/sounds/dream.mp3', function(buffer) {
    dreamSound.setBuffer(buffer);
    dreamSound.setLoop(true);   // تكرار الصوت
    dreamSound.setVolume(0.5);  // مستوى الصوت
    dreamSound.play();
});

# ===============================
# MIX PLATFORM - ENV CONFIG
# ===============================

# 🔥 ENVIRONMENT
NODE_ENV=development
APP_NAME=MixPlatform
APP_VERSION=1.0.0

# 🔐 SECURITY
JWT_SECRET=CHANGE_THIS_SECRET
JWT_EXPIRES_IN=7d

# ⚙️ BACKEND
BACKEND_HOST=localhost
BACKEND_PORT=3000
API_BASE=/api

# 🌐 FRONTEND
FRONTEND_URL=http://localhost:8080

# 🔗 API CONNECTION (الأهم)
MIX_API_BASE=http://localhost:3000/api

# 🧠 AI MODULE
AI_ENABLED=true

# 🌙 DREAM ENGINE
DREAM_ENGINE_ENABLED=true

# 🧬 ENERGY SYSTEM
ENERGY_UPDATE_INTERVAL=60

# 💰 WALLET
DEFAULT_BALANCE=100

# 💬 SOCIAL
MAX_POST_LENGTH=500

# 🎮 GAMES
GAMES_ENABLED=true

# 🌐 THREE.JS
THREEJS_ENABLED=true

# 📁 STORAGE
STORAGE_PATH=./storage
USERS_FILE=./storage/users.json
SOCIAL_FILE=./storage/social.json
MESSAGES_FILE=./storage/messages.json
WALLETS_FILE=./storage/wallets.json
DREAMS_FILE=./storage/dreams.json
DREAM_WORLDS_FILE=./storage/dream_worlds.json

# 📝 LOGS
LOG_LEVEL=info
BACKEND_LOG=./storage/logs/backend.log
SYSTEM_LOG=./logs/system.log

# 🐳 DOCKER
DOCKER_PORT=3000

# 🧪 DEBUG
DEBUG_MODE=true
